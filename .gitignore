# 日誌檔案 (Logs)
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 依賴套件 (Dependencies) - 這個最重要，絕對不要 commit
node_modules/
dist/
dist-ssr/
*.local

# 編輯器相關 (Editor folders)
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 編譯產物 (Build output)
# 如果你使用 GitHub Actions 自動編譯，本地的 dist 資料夾就不需要上傳
dist/

# 環境變數 (Environment variables)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
